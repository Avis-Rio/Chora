# Chora 环境变量配置
# 复制此文件为 .env 并填入真实密钥
# .env 已被 .gitignore 忽略，不会提交到 Git

# Groq API (Whisper 音频转录)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (封面图生成)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://yunwu.ai/v1beta/models/gemini-3.1-flash-image-preview:generateContent
GEMINI_MODEL=gemini-3.1-flash-image-preview

# LLM API (内容改写，OpenAI 兼容格式)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://yunwu.ai/v1/chat/completions
LLM_MODEL=claude-sonnet-4-20250514

# 飞书多维表格 (可选)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BASE_ID=your_feishu_base_id
FEISHU_TABLE_ID=your_feishu_table_id

# Vercel 部署域名 (可选，用于封面 URL)
VERCEL_BASE_URL=https://your-app.vercel.app
